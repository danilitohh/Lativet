# Variables de entorno para Lativet
# Copia este archivo como .env y ajusta si es necesario.

# Servidor
LATIVET_HOST=127.0.0.1
LATIVET_PORT=8000
LATIVET_DEBUG=1

# Datos (usa /tmp en serverless como Vercel)
# LATIVET_DATA_DIR=/tmp/lativet

# PostgreSQL (Supabase) - usa la cadena de conexion del proyecto
# DATABASE_URL=postgresql://USER:PASSWORD@HOST:PORT/postgres?sslmode=require

# SMTP (opcional)
# SMTP_FROM=
# SMTP_APP_PASSWORD=
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_ENABLED=true
